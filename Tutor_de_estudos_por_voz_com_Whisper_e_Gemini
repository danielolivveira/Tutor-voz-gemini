        "from google import genai\n",
        "from google.colab import userdata\n",
        "\n",
        "# Configura a chave de API do Gemini via Secrets do Colab\n",
        "client = genai.Client(api_key=userdata.get('GEMINI_API_KEY'))\n",
        "\n",
        "# Envia a transcrição do áudio para o Gemini\n",
        "response = client.models.generate_content(\n",
        "    model='gemini-2.5-flash',\n",
        "    contents=transcription,\n",
        "    config={\n",
        "        \"system_instruction\": \"Você é um professor tutor amigável e didático. Responda sempre em português de forma clara e simples, como se estivesse explicando para um aluno do ensino médio.\"\n",
        "    }\n",
        ")\n",
        "\n",
        "# Obtém a resposta gerada pelo Gemini\n",
        "gemini_response = response.text\n",
        "print(gemini_response)"
